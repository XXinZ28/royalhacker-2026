# Copy to .env (gitignored) and fill in real values.

# n8n instance base URL, e.g. https://your-subdomain.app.n8n.cloud
N8N_BASE_URL=

# n8n Public API JWT (used only for provisioning workflows via API).
# DO NOT COMMIT. DO NOT PASTE INTO LOVABLE PROJECT.
N8N_API_TOKEN=

# Public webhook URLs exposed to Lovable (fill in after workflows are deployed).
VITE_N8N_INTAKE_URL=
VITE_N8N_MATCH_URL=
VITE_N8N_CHAT_POLL_URL=
VITE_N8N_CHAT_SEND_URL=
VITE_N8N_MATCH_END_URL=

# Google Sheet ID for the user_vectors table (from the Sheet URL).
GOOGLE_SHEET_ID=
