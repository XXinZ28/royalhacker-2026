# Copy to .env.local and fill in

# n8n webhook URL for emotion inference (optional — falls back to local)
VITE_N8N_EMOTION_URL=

# Claude API (only needed if calling Anthropic directly instead of through n8n)
ANTHROPIC_API_KEY=

# OpenAI (alternative to Claude)
OPENAI_API_KEY=

# Demo mode — when true, chat runs at 10x speed for pitch
VITE_DEMO_MODE=false
